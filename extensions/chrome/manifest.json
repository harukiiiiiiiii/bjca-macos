{
  "manifest_version": 3,
  "name": "BJCA Certificate Bridge (macOS)",
  "version": "2.1.0",
  "description": "Replaces the Windows ActiveX control with native macOS WebSocket bridge for BJCA USB Key operations.",
  "permissions": [
    "nativeMessaging",
    "webRequest",
    "activeTab"
  ],
  "host_permissions": [
    "https://127.0.0.1:21061/*",
    "https://jspec.com.cn/*",
    "https://www.jspec.com.cn/*",
    "https://*.sgcc.com.cn/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://jspec.com.cn/*",
        "https://www.jspec.com.cn/*",
        "https://*.sgcc.com.cn/*"
      ],
      "js": ["page-bridge.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": [
        "https://jspec.com.cn/*",
        "https://www.jspec.com.cn/*",
        "https://*.sgcc.com.cn/*"
      ],
      "js": ["inject.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
